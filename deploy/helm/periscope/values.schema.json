{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Periscope Helm values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1,
      "description": "v1 supports single replica only (in-memory session store)."
    },
    "auth": {
      "type": "object",
      "properties": {
        "authorization": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["shared", "tier", "raw"]
            },
            "auditAdminGroups": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "description": "IdP groups granted full /api/audit visibility. Independent of authz mode. See docs/setup/audit.md."
            }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["existing", "plain", "external", "native"]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "existing" } }, "required": ["mode"] },
          "then": {
            "properties": {
              "existing": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "minLength": 1 }
                }
              }
            },
            "required": ["existing"]
          }
        },
        {
          "if": { "properties": { "mode": { "const": "plain" } }, "required": ["mode"] },
          "then": {
            "properties": {
              "plain": {
                "type": "object",
                "required": ["clientSecret"],
                "properties": {
                  "clientSecret": { "type": "string", "minLength": 1 }
                }
              }
            },
            "required": ["plain"]
          }
        },
        {
          "if": { "properties": { "mode": { "const": "external" } }, "required": ["mode"] },
          "then": {
            "properties": {
              "external": {
                "type": "object",
                "required": ["storeName", "remoteKey"],
                "properties": {
                  "storeName": { "type": "string", "minLength": 1 },
                  "remoteKey": { "type": "string", "minLength": 1 }
                }
              }
            },
            "required": ["external"]
          }
        }
      ]
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
      "then": {
        "required": ["host"],
        "properties": {
          "host": { "type": "string", "minLength": 1 }
        }
      }
    },
    "audit": {
      "type": "object",
      "description": "Audit pipeline persistence. See docs/setup/audit.md.",
      "properties": {
        "enabled": { "type": "boolean" },
        "retentionDays": { "type": "integer", "minimum": 0 },
        "maxSizeMB": { "type": "integer", "minimum": 0 },
        "vacuumInterval": {
          "type": "string",
          "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h)$",
          "description": "Go duration string (e.g. 24h, 6h, 30m)."
        },
        "storage": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["pvc", "emptyDir"]
            },
            "size": {
              "type": "string",
              "pattern": "^[0-9]+(Mi|Gi)$",
              "description": "PVC request size (e.g. 5Gi). Used only when storage.type=pvc."
            },
            "storageClass": { "type": "string" },
            "accessMode": {
              "type": "string",
              "enum": ["ReadWriteOnce", "ReadWriteMany", "ReadWriteOncePod"]
            }
          }
        }
      }
    },
    "watchStreams": {
      "type": "object",
      "description": "Watch (SSE) push streams for live resource lists. Server defaults to all-on; this block is the operator-facing opt-out / subset / per-user cap.",
      "properties": {
        "kinds": {
          "type": "string",
          "description": "Empty/unset or 'all' = all on (server default). 'off'/'none' = disable. Otherwise a comma-separated mix of per-kind tokens (pods, events, configmaps, deployments, services, …) and group aliases (core, config, workloads, networking, storage, cluster). The server is the source of truth for the registry — see cmd/periscope/main.go::watchKinds; this schema mirrors the current tokens so unknown values fail at deploy time.",
          "pattern": "^\\s*$|^\\s*(?:all|off|none)\\s*$|^\\s*(?:(?:pods|events|configmaps|resourcequotas|limitranges|serviceaccounts|deployments|statefulsets|daemonsets|replicasets|jobs|cronjobs|horizontalpodautoscalers|poddisruptionbudgets|services|ingresses|networkpolicies|endpointslices|ingressclasses|pvs|pvcs|storageclasses|nodes|namespaces|priorityclasses|runtimeclasses|core|config|workloads|networking|storage|cluster)(?:\\s*,\\s*(?:pods|events|configmaps|resourcequotas|limitranges|serviceaccounts|deployments|statefulsets|daemonsets|replicasets|jobs|cronjobs|horizontalpodautoscalers|poddisruptionbudgets|services|ingresses|networkpolicies|endpointslices|ingressclasses|pvs|pvcs|storageclasses|nodes|namespaces|priorityclasses|runtimeclasses|core|config|workloads|networking|storage|cluster))*\\s*)$"
        },
        "perUserLimit": {
          "type": "integer",
          "minimum": 0,
          "description": "Concurrent SSE streams per OIDC subject. 0 disables the cap (not recommended)."
        }
      }
    },
    "pdb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "clusterRBAC": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "podIdentity": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "exec": {
      "type": "object",
      "description": "Pod exec global defaults. Per-cluster overrides in clusters[].exec take precedence. See docs/setup/pod-exec.md.",
      "properties": {
        "serverIdleSeconds":   { "type": "integer", "minimum": 1 },
        "idleWarnSeconds":     { "type": "integer", "minimum": 1 },
        "heartbeatSeconds":    { "type": "integer", "minimum": 1 },
        "maxSessionsPerUser":  { "type": "integer", "minimum": 1 },
        "maxSessionsTotal":    { "type": "integer", "minimum": 1 },
        "probeClustersOnBoot": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "agent": {
      "type": "object",
      "description": "Optional agent backend wiring (#42). Default off; enable to host the per-deployment CA + tunnel TLS listener so periscope-agent pods on managed clusters can dial in.",
      "properties": {
        "enabled":      { "type": "boolean" },
        "listenAddr":   { "type": "string", "pattern": "^:[0-9]+$", "description": "Bind addr for the dedicated TLS listener hosting /api/agents/connect. Format :PORT." },
        "tunnelSANs":   { "type": "string", "description": "Comma-separated DNS names baked into the server cert presented on the tunnel. Must include whatever hostname agents dial." },
        "caSecretName": { "type": "string", "minLength": 1, "maxLength": 253, "description": "K8s Secret holding the per-deployment CA. Pre-created empty by the chart; server fills on first boot." },
        "tunnelService": {
          "type": "object",
          "description": "Optional second Service exposing the tunnel listener externally. Default disabled — operators wire NLB/TCP-LB themselves or port-forward for testing.",
          "properties": {
            "enabled":     { "type": "boolean" },
            "type":        { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "port":        { "type": "integer", "minimum": 1, "maximum": 65535 },
            "annotations": { "type": "object" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":    { "type": "string", "minLength": 1 },
          "backend": { "type": "string", "enum": ["eks", "kubeconfig", "in-cluster", "agent"] },
          "exec": {
            "type": "object",
            "description": "Per-cluster pod-exec overrides. Partial overrides are fine — omitted fields fall back to the global .exec defaults.",
            "properties": {
              "enabled":            { "type": "boolean" },
              "serverIdleSeconds":  { "type": "integer", "minimum": 1 },
              "idleWarnSeconds":    { "type": "integer", "minimum": 1 },
              "heartbeatSeconds":   { "type": "integer", "minimum": 1 },
              "maxSessionsPerUser": { "type": "integer", "minimum": 1 },
              "maxSessionsTotal":   { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        }
      }
    }
  }
}
